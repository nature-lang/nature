import syscall

fn main():void! {
    var s = syscall.stat('./asserts/stat.txt')
    println('stat regular:', syscall.stat_is_reg(s.mode))
    println('stat size positive:', s.size > 0)
    println('stat link count positive:', s.nlink > 0)

    var fd = syscall.open('./asserts/stat.txt', syscall.O_RDONLY, 0666)
    var s2 = syscall.fstat(fd)
    syscall.close(fd)

    println('fstat regular:', syscall.stat_is_reg(s2.mode))
    println('stat and fstat size match:', s.size == s2.size)

    // 不存在的文件
    var s3 = syscall.stat('./asserts/nofound.txt') catch err {
        println('missing stat failed')
        return
    }
}
