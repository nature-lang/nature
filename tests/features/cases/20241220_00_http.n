import co
import http
import http.client

fn main():void! {
    var app = http.server()

    app.get('/', fn(http.request_t req, ref<http.response_t> res):void! {
        res.send('hello nature')
    })

    app.get('/close', fn(http.request_t req, ref<http.response_t> res):void! {
        res.send('closed')
        app.close()
    })

    go fn():void! {
        app.listen(8888)
        println('server is closed')
    }()

    co.sleep(500)
    var response = client.new().get('http://127.0.0.1:8888/').send()
    println(response.text())
    client.new().get('http://127.0.0.1:8888/close').send()
    co.sleep(500)
}
